[Unit]
Description=Stock Flow daily Telegram backup
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/var/www/stock_flow
EnvironmentFile=/var/www/stock_flow/.env
# TELEGRAM_BOT_TOKEN and TELEGRAM_STORAGE_CHAT_ID must be provided by the env file.
ExecStart=/var/www/stock_flow/venv/bin/python /var/www/stock_flow/stockflow_telegram_backup.py
